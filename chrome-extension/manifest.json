{
  "manifest_version": 3,
  "name": "CoachIQ NLM Sync",
  "version": "1.0.0",
  "description": "Syncs coaching session transcripts from CoachIQ to Google NotebookLM",
  "permissions": [],
  "host_permissions": [
    "*://notebooklm.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://coachiq.vercel.app/*",
        "http://localhost:3000/*",
        "https://*.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
