# Fathom API
COACHIQ_FATHOM_API_KEY=your_fathom_api_key
COACHIQ_FATHOM_WEBHOOK_SECRET=whsec_your_webhook_secret

# NotebookLM (notebooklm-py)
COACHIQ_NOTEBOOKLM_STORAGE_PATH=~/.notebooklm/todd_storage_state.json

# PostgreSQL (Cloud SQL via Auth Proxy connects on localhost)
COACHIQ_DATABASE_URL=postgresql+asyncpg://coachiq:password@localhost:5432/coachiq

# Google Drive service account
COACHIQ_GOOGLE_SERVICE_ACCOUNT_JSON=./service-account.json
COACHIQ_DRIVE_ROOT_FOLDER_NAME=CoachIQ

# Health dashboard token
COACHIQ_HEALTH_TOKEN=change-me-in-production

# Email alerting
COACHIQ_ALERT_EMAIL_TO=dallas@vsinsights.com
COACHIQ_ALERT_EMAIL_FROM=coachiq@growwithcocreate.com
COACHIQ_SMTP_HOST=smtp.gmail.com
COACHIQ_SMTP_PORT=587
COACHIQ_SMTP_USER=
COACHIQ_SMTP_PASSWORD=

# Coach info
COACHIQ_COACH_EMAIL=todd@growwithcocreate.com
COACHIQ_COACH_NAME=Todd Zimbelman

# Chat model routing — when an OpenRouter key is set, the daily brief,
# synopsis, and prep-brief calls go through OpenRouter (one API, many models).
# Falls back to OpenAI directly if not set. Embeddings stay on OpenAI.
# Either naming convention works:
OPEN_ROUTER_API_KEY=
# OPENROUTER_API_KEY=
# Default model when OpenRouter is in use. Override per workload if needed.
# Examples: anthropic/claude-sonnet-4.6, openai/gpt-5, google/gemini-2.5-pro
BRIEF_MODEL=anthropic/claude-sonnet-4.6
# Optional — recommended by OpenRouter for attribution.
OPENROUTER_REFERER=https://coachiq.vercel.app

# Calendar title filter (regex, case-insensitive)
COACHIQ_COACHING_TITLE_FILTER=coaching|executive coaching|session
