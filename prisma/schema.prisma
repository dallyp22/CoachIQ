generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector, pgcrypto]
}

// ─── ENUMS ────────────────────────────────────────────

enum ClientStatus {
  ACTIVE
  PAUSED
  CHURNED
  PROSPECT
}

enum BillingCadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM_DAYS
}

enum CoachRole {
  OWNER // Todd — everything, including the billing Danger Zone
  ADMIN // Joel / mgmt — practice-wide visibility + coach management
  COACH // sees only their own clients and data
}

enum CoachStatus {
  INVITED // row exists, Clerk invite sent, not yet signed in
  ACTIVE
  INACTIVE // soft-removed; historical rows keep their FK
}

enum StepStatus {
  PENDING
  OK
  FAILED
}

enum MeetingCadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
  AD_HOC
}

enum SessionStatus {
  CAPTURED
  REVIEWED
  ARCHIVED
}

enum TimeEntryStatus {
  UNBILLED
  STAGED
  INVOICED
  PAID
  WRITTEN_OFF
}

enum InvoiceStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  SENT
  PAID
  OVERDUE
  VOID
}

enum SessionSource {
  FATHOM
  CALENDAR
  MANUAL
}

enum JobType {
  GENERATE_EMBEDDING
  GENERATE_SYNOPSIS
  GENERATE_BRIEF
  INJECT_NLM
  CALENDAR_SYNC
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── MODELS ───────────────────────────────────────────

// ─── COACHES ──────────────────────────────────────────

/// One row per person with an account. The practice-wide config that is NOT
/// per-coach (Stripe, AI keys, invoice numbering) stays on CoachSettings.
///
///   Fathom webhook ──► routed by workEmails ──► HMAC vs THIS coach's secret
///   Calendar sync   ──► googleCalendarId (shared service account)
///   Drive writes    ──► driveRootFolderId (folder in the coach's OWN Drive)
///
/// `status` gates LOGIN linking only — the data pipes above run for any
/// non-INACTIVE coach whose integrations are configured, so a coach's first
/// test recording works minutes after Add Coach, before they ever sign in.
model Coach {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  /// Clerk invite + login target.
  loginEmail          String      @unique
  /// Addresses the coach records/organizes meetings under. Used to route
  /// incoming recordings and to exclude the coach when picking the client
  /// attendee. Often differs from loginEmail.
  workEmails          String[]    @default([])
  /// Stamped on first sign-in from the Clerk invitation's public_metadata.
  clerkUserId         String?     @unique
  role                CoachRole   @default(COACH)
  status              CoachStatus @default(INVITED)
  /// Per-step Add Coach outcomes, so a half-created coach is visible and
  /// retryable instead of silently inert.
  inviteStatus        StepStatus  @default(PENDING)
  fathomStatus        StepStatus  @default(PENDING)
  /// Encrypted at rest via src/lib/secrets.ts — never read these columns
  /// directly, go through decryptOptional().
  fathomApiKey        String?
  fathomWebhookSecret String?
  /// Fathom's id for the webhook we registered. The API has no list endpoint
  /// (only create and delete), so this is the only way to know we already
  /// registered one — it makes a double-submitted Add Coach idempotent
  /// instead of creating a second webhook that double-ingests every meeting.
  fathomWebhookId     String?
  googleCalendarId    String?
  /// Regex, validated at save time. Null falls back to the practice default.
  coachingTitleFilter String?
  calendarSyncEnabled Boolean     @default(true)
  /// Folder in the coach's OWN Drive, shared to the app's Drive identity and
  /// pinned by ID — never resolved by name (name lookup collides when two
  /// coaches have a same-named client).
  driveRootFolderId   String?
  /// Dollars, matching every other money column. Applies as the pre-fill when
  /// a CLIENT is created; invoice rates freeze onto TimeEntry at session time.
  defaultHourlyRate   Decimal?    @db.Decimal(10, 2)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  clients           Client[]
  billingGroups     BillingGroup[]
  pendingRecordings PendingRecording[]

  @@index([status])
  @@map("coaches")
}

/// A recording that verified against a coach's webhook secret but matched no
/// client. Today these were a Drive drop plus a console.warn; with per-coach
/// Drive roots the owner would have to spelunk N different Drives to find
/// them, so the row is the reviewable record and the Drive file is the payload.
model PendingRecording {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachId           String    @db.Uuid
  fathomRecordingId String
  inviteeEmails     String[]  @default([])
  driveFileId       String?
  title             String?
  recordedAt        DateTime?
  createdAt         DateTime  @default(now())
  resolvedAt        DateTime?

  coach Coach @relation(fields: [coachId], references: [id])

  @@unique([coachId, fathomRecordingId])
  @@index([coachId, resolvedAt])
  @@map("pending_recordings")
}

// ─── CLIENTS ──────────────────────────────────────────

model Client {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachId             String         @db.Uuid
  name                String
  displayName         String?
  /// Unique per coach, not globally: two coaches may legitimately serve the
  /// same person, and recording→client matching is coach-scoped.
  email               String
  secondaryEmails     String[]       @default([])
  phone               String?
  company             String?
  address             Json?
  hourlyRate          Decimal        @default(300) @db.Decimal(10, 2)
  billingCadence      BillingCadence @default(MONTHLY)
  customCadenceDays   Int?
  billingContactName  String?
  billingContactEmail String?
  billingPausedUntil  DateTime?
  billingNotes        String?
  nextInvoiceDueAt    DateTime?
  billingTimezone     String?
  retainer            Decimal        @default(0) @db.Decimal(10, 2)
  meetingCadence      MeetingCadence @default(BIWEEKLY)
  stripeCustomerId    String?
  billingGroupId      String?        @db.Uuid
  notebookId          String?
  driveFolderId       String?
  allowsFathom        Boolean        @default(true)
  status              ClientStatus   @default(ACTIVE)
  notes               String?
  tags                String[]       @default([])
  sessionCount        Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  sessions     Session[]
  transcripts  Transcript[]
  timeEntries  TimeEntry[]
  invoices     Invoice[]
  prepBriefs   PrepBrief[]
  billingGroup BillingGroup? @relation(fields: [billingGroupId], references: [id])
  coach        Coach         @relation(fields: [coachId], references: [id])

  @@unique([coachId, email])
  @@index([status])
  @@index([email])
  @@index([coachId])
  @@index([nextInvoiceDueAt])
  @@index([billingGroupId])
  @@map("clients")
}

/// Every member client must belong to the group's coach — enforced at
/// member-add. Without a coach on the group, a group invoice (which has no
/// single client) has no owner, and coach-scoped invoice lists drop it.
model BillingGroup {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachId             String         @db.Uuid
  name                String
  displayName         String?
  billingContactName  String?
  billingContactEmail String
  ccEmails            String[]       @default([])
  address             Json?
  // Optional override. When null, each line item bills at the member's own
  // hourlyRate captured on the TimeEntry at session time.
  hourlyRate          Decimal?       @db.Decimal(10, 2)
  billingCadence      BillingCadence @default(MONTHLY)
  customCadenceDays   Int?
  billingPausedUntil  DateTime?
  nextInvoiceDueAt    DateTime?
  billingTimezone     String?
  retainer            Decimal        @default(0) @db.Decimal(10, 2)
  stripeCustomerId    String?
  status              ClientStatus   @default(ACTIVE)
  notes               String?
  tags                String[]       @default([])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  members  Client[]
  invoices Invoice[]
  coach    Coach     @relation(fields: [coachId], references: [id])

  @@index([status])
  @@index([coachId])
  @@index([nextInvoiceDueAt])
  @@map("billing_groups")
}

model Session {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId          String        @db.Uuid
  fathomRecordingId String?       @unique
  sessionSource     SessionSource @default(FATHOM)
  title             String
  date              DateTime
  durationMinutes   Int
  billableMinutes   Int
  recordingUrl      String?
  shareUrl          String?
  fathomSummary     String?
  actionItems       Json?
  synopsis          String?
  transcriptDriveId String?
  nlmInjected       Boolean       @default(false)
  calendarEventId   String?       @unique
  status            SessionStatus @default(CAPTURED)
  createdAt         DateTime      @default(now())

  client     Client      @relation(fields: [clientId], references: [id])
  transcript Transcript?
  timeEntry  TimeEntry?

  @@index([clientId, date(sort: Desc)])
  @@index([fathomRecordingId])
  @@map("sessions")
}

model Transcript {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId      String   @unique @db.Uuid
  clientId       String   @db.Uuid
  fullText       String
  rawSegments    Json?
  wordCount      Int      @default(0)
  speakerStats   Json?
  embeddingModel String?
  topics         String[] @default([])
  createdAt      DateTime @default(now())

  // Declared so Prisma SEES these columns and leaves them alone. They are
  // created and maintained by raw SQL in 20260329024112_add_pgvector_embedding
  // (embedding is ivfflat-indexed; search_text is GENERATED ALWAYS from
  // fullText). Before this declaration, `prisma migrate dev` diffed them as
  // drift and proposed DROPping 602+ rows of embeddings. Never write to these
  // through the Prisma client — they are raw-SQL territory.
  embedding   Unsupported("vector(1536)")?
  search_text Unsupported("tsvector")?

  session Session @relation(fields: [sessionId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id])

  @@index([clientId, createdAt(sort: Desc)])
  @@map("transcripts")
}

model TimeEntry {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId     String?         @unique @db.Uuid
  clientId      String          @db.Uuid
  date          DateTime
  description   String?
  billableHours Decimal         @db.Decimal(5, 2)
  hourlyRate    Decimal         @db.Decimal(10, 2)
  amount        Decimal         @db.Decimal(10, 2)
  isManual      Boolean         @default(false)
  status        TimeEntryStatus @default(UNBILLED)
  invoiceId     String?         @db.Uuid
  createdAt     DateTime        @default(now())

  session Session? @relation(fields: [sessionId], references: [id])
  client  Client   @relation(fields: [clientId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([clientId, status])
  @@index([status])
  @@map("time_entries")
}

model Invoice {
  id                      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Exactly one of clientId / groupId is set. Enforced via DB CHECK constraint
  // `invoice_billable_xor` added in the billing-groups migration.
  clientId                String?       @db.Uuid
  groupId                 String?       @db.Uuid
  invoiceNumber           String        @unique
  periodStart             DateTime
  periodEnd               DateTime
  lineItems               Json
  subtotal                Decimal       @db.Decimal(10, 2)
  tax                     Decimal       @default(0) @db.Decimal(10, 2)
  total                   Decimal       @db.Decimal(10, 2)
  status                  InvoiceStatus @default(DRAFT)
  stripeInvoiceId         String?
  stripePaymentUrl        String?
  sentAt                  DateTime?
  paidAt                  DateTime?
  notes                   String?
  // Snapshot fields: populated at DRAFT creation, frozen until "Refresh from billable" is clicked.
  // Existing rows backfilled from current client values in the same migration.
  snapshotClientName      String?
  snapshotBillingEmail    String?
  snapshotBillingCcEmails String[]      @default([])
  snapshotHourlyRate      Decimal?      @db.Decimal(10, 2)
  parentInvoiceId         String?       @db.Uuid
  lastReminderSentAt      DateTime?
  createdAt               DateTime      @default(now())

  client      Client?             @relation(fields: [clientId], references: [id])
  group       BillingGroup?       @relation(fields: [groupId], references: [id])
  timeEntries TimeEntry[]
  adjustments InvoiceAdjustment[]

  @@index([clientId])
  @@index([groupId])
  @@index([status])
  @@map("invoices")
}

model InvoiceAdjustment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String   @db.Uuid
  kind        String // "credit" | "discount" | "expense"
  amount      Decimal  @db.Decimal(10, 2) // signed: negative = credit/discount
  description String
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_adjustments")
}

model BillingAuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event     String // INVOICE_DRAFT | INVOICE_APPROVED | INVOICE_SENT | INVOICE_PAID | INVOICE_VOID | RESET | RETAINER_ADD | RETAINER_APPLY | MANUAL_EDIT | CRON_GEN | MANUAL_GEN | CADENCE_CHANGE | GROUP_CREATED | GROUP_UPDATED | GROUP_DELETED | GROUP_MEMBER_ADDED | GROUP_MEMBER_REMOVED
  actor     String? // Clerk user id (null = system/cron)
  clientId  String?  @db.Uuid
  groupId   String?  @db.Uuid
  invoiceId String?  @db.Uuid
  payload   Json?
  createdAt DateTime @default(now())

  @@index([clientId, createdAt(sort: Desc)])
  @@index([groupId, createdAt(sort: Desc)])
  @@index([invoiceId])
  @@index([event, createdAt(sort: Desc)])
  @@map("billing_audit_logs")
}

model PrepBrief {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId          String    @db.Uuid
  targetSessionDate DateTime
  content           String
  contextSessions   String[]  @default([]) @db.Uuid
  delivered         Boolean   @default(false)
  deliveredAt       DateTime?
  createdAt         DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId, targetSessionDate])
  @@map("prep_briefs")
}

model CoachSettings {
  id                       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachName                String         @default("Todd Zimbelman")
  coachEmail               String         @default("todd@growwithcocreate.com")
  businessName             String         @default("Co-Create Coaching")
  defaultHourlyRate        Decimal        @default(300) @db.Decimal(10, 2)
  defaultBillingCadence    BillingCadence @default(MONTHLY)
  defaultBillingDayOfMonth Int?
  autoApproveUnderCents    Int?
  invoicePrefix            String         @default("CIQ")
  invoiceNumberPadding     Int            @default(4)
  timezone                 String         @default("America/Chicago")
  stripeAccountId          String?
  stripeSecretKey          String?
  googleCalendarId         String?
  fathomWebhookSecret      String?
  coachingTitleFilter      String?
  briefDeliveryMinutes     Int            @default(30)
  calendarSyncEnabled      Boolean        @default(false)
  nlmLastSynced            DateTime?
  openaiApiKey             String?
  anthropicApiKey          String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@map("coach_settings")
}

// ─── JOB QUEUE ────────────────────────────────────────

model Job {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        JobType
  payload     Json
  status      JobStatus @default(PENDING)
  error       String?
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  @@index([status, createdAt])
  @@index([type, status])
  @@map("jobs")
}
